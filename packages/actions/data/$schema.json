{
	"$defs": {
		"crystalInputOutput": {
			"additionalProperties": false,
			"properties": {
				"amount": { "type": "number" },
				"id": { "type": "string" },
				"type": { "const": "crystal", "type": "string" }
			},
			"required": ["amount", "id", "type"],
			"type": "object"
		},
		"currencyInputOutput": {
			"additionalProperties": false,
			"properties": {
				"amount": { "type": "number" },
				"id": {
					"enum": [
						"bingo-point",
						"bit",
						"coin",
						"copper",
						"forge-second",
						"gem",
						"medal",
						"mote",
						"north-star",
						"online-second",
						"pest",
						"second",
						"usd"
					],
					"type": "string"
				},
				"type": { "const": "currency", "type": "string" }
			},
			"required": ["amount", "id", "type"],
			"type": "object"
		},
		"itemInputOutput": {
			"additionalProperties": false,
			"properties": {
				"amount": { "type": "number" },
				"id": { "type": "string" },
				"type": { "const": "item", "type": "string" }
			},
			"required": ["amount", "id", "type"],
			"type": "object"
		},
		"petInputOutput": {
			"additionalProperties": false,
			"properties": {
				"amount": { "type": "number" },
				"id": { "type": "string" },
				"type": { "const": "pet", "type": "string" }
			},
			"required": ["amount", "id", "type"],
			"type": "object"
		}
	},
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"additionalProperties": false,
	"properties": {
		"$schema": {
			"type": "string"
		},
		"actions": {
			"items": {
				"additionalProperties": false,
				"properties": {
					"inputs": {
						"items": {
							"anyOf": [
								{ "$ref": "#/$defs/crystalInputOutput" },
								{ "$ref": "#/$defs/currencyInputOutput" },
								{ "$ref": "#/$defs/itemInputOutput" },
								{ "$ref": "#/$defs/petInputOutput" }
							]
						},
						"type": "array"
					},
					"outputs": {
						"items": {
							"anyOf": [
								{ "$ref": "#/$defs/crystalInputOutput" },
								{ "$ref": "#/$defs/currencyInputOutput" },
								{ "$ref": "#/$defs/itemInputOutput" },
								{ "$ref": "#/$defs/petInputOutput" }
							]
						},
						"type": "array"
					},
					"place": {
						"items": {
							"anyOf": [
								{
									"additionalProperties": false,
									"properties": {
										"left": { "$ref": "#/$defs/itemInputOutput" },
										"right": { "$ref": "#/$defs/itemInputOutput" },
										"type": { "const": "anvil", "type": "string" }
									},
									"required": ["left", "right", "type"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"type": { "const": "forge", "type": "string" }
									},
									"required": ["type"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"type": { "const": "inventory", "type": "string" }
									},
									"required": ["type"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"id": { "type": "string" },
										"type": { "const": "npc", "type": "string" }
									},
									"required": ["id", "type"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"type": { "const": "time-pocket", "type": "string" }
									},
									"required": ["type"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"type": { "const": "website", "type": "string" },
										"url": { "format": "uri", "type": "string" }
									},
									"required": ["type", "url"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"grid": {
											"items": {
												"anyOf": [
													{ "$ref": "#/$defs/itemInputOutput" },
													{ "type": "null" }
												]
											},
											"maxItems": 9,
											"minItems": 9,
											"type": "array"
										},
										"type": { "const": "workbench", "type": "string" }
									},
									"required": ["grid", "type"],
									"type": "object"
								}
							]
						},
						"minItems": 1,
						"type": "array"
					},
					"requirements": {
						"items": {
							"anyOf": [
								{
									"additionalProperties": false,
									"properties": {
										"collection": { "enum": ["GEMSTONE"], "type": "string" },
										"tier": { "type": "number" },
										"type": { "const": "COLLECTION", "type": "string" }
									},
									"required": ["collection", "tier", "type"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"tier": { "type": "number" },
										"type": {
											"const": "HEART_OF_THE_MOUNTAIN",
											"type": "string"
										}
									},
									"required": ["tier", "type"],
									"type": "object"
								},
								{
									"additionalProperties": false,
									"properties": {
										"level": { "type": "number" },
										"skill": {
											"enum": ["MINING"],
											"type": "string"
										},
										"type": { "const": "SKILL", "type": "string" }
									},
									"required": ["level", "skill", "type"],
									"type": "object"
								}
							]
						},
						"type": "array"
					}
				},
				"required": ["inputs", "outputs", "place"],
				"type": "object"
			},
			"type": "array"
		}
	},
	"required": ["actions"]
}
